# GitHub App credentials for bot identity (preferred over personal token)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Set one of these private key values:
# 1) Raw PEM (multi-line)
# GITHUB_APP_PRIVATE_KEY=
# 2) Base64-encoded PEM (single line)
GITHUB_APP_PRIVATE_KEY_B64=

# Optional commit identity override used by OpenCode runtime
BOT_GIT_NAME=OpenCode Bot
BOT_GIT_EMAIL=opencode-bot@users.noreply.github.com
