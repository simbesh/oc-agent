# Telegram bot settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# GitHub CLI token (full repo read/write as requested)
# Recommended scopes for classic PAT: repo, read:org, workflow
GH_TOKEN=

# Optional: use a GitHub App instead of personal token.
# If these are set, the stack mints an installation token at startup
# and uses it for gh commands (preferred for bot identity).
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_PRIVATE_KEY_B64=

# Optional: force commit author/committer identity for git commits
# created by OpenCode (no git config writes required).
# BOT_GIT_NAME=OpenCode Bot
# BOT_GIT_EMAIL=opencode-bot@users.noreply.github.com

# OpenCode model defaults used by the Telegram bot
OPENCODE_MODEL_PROVIDER=opencode
OPENCODE_MODEL_ID=big-pickle

# Optional OpenCode server basic auth
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=

# Provider credentials (set what you actually use)
# OPENCODE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional bot behavior
BOT_LOCALE=en
MESSAGE_FORMAT_MODE=markdown
SERVICE_MESSAGES_INTERVAL_SEC=5
HIDE_THINKING_MESSAGES=false
HIDE_TOOL_CALL_MESSAGES=false
LOG_LEVEL=info

# Optional host path mounted into /workspace in the opencode service.
# If omitted, Docker Compose uses a persistent named volume called "workspace".
# WORKSPACE_DIR=/absolute/path/on/host
